{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/PaulKinlan/web-ai-showcase/media/manifest.schema.json",
  "title": "web-ai-showcase media manifest",
  "type": "object",
  "required": ["name", "provenanceRules", "generated", "count", "assets"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "provenanceRules": { "type": "array", "items": { "type": "string" } },
    "generated": { "type": "string", "format": "date" },
    "count": { "type": "integer", "minimum": 0 },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "source",
          "sourceUrl",
          "creator",
          "license",
          "retrieved",
          "formats",
          "width",
          "height"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string" },
          "familyRelevance": { "type": "string" },
          "source": { "type": "string" },
          "sourceUrl": { "type": "string", "format": "uri" },
          "creator": { "type": "string" },
          "license": {
            "type": "string",
            "description": "SPDX identifier (e.g. CC-BY-4.0, CC0-1.0) or an explicit license label."
          },
          "licenseName": { "type": "string" },
          "licenseUrl": { "type": "string" },
          "attribution": { "type": "string" },
          "retrieved": { "type": "string", "format": "date" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "formats": {
            "type": "object",
            "required": ["jpg"],
            "properties": {
              "avif": { "$ref": "#/$defs/format" },
              "webp": { "$ref": "#/$defs/format" },
              "jpg": { "$ref": "#/$defs/format" }
            }
          }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "id": { "type": "string" },
          "query": { "type": "string" },
          "source": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "format": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "bytesKB": { "type": "number" }
      }
    }
  }
}
