{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lineage value/quality record (inventory/lineage/value-records.ndjson, one per line)",
  "description": "Transparent, EVIDENCE-GATED value assessment. Scores are null / 'insufficient-evidence' / 'eval-pending' where direct evidence is absent. downloads/likes are WEAK context only. Never asserts perf-equivalence or 'badly trained' from metadata.",
  "type": "object",
  "required": ["id", "task", "relationship", "dimensions", "overallConfidence", "evalPending"],
  "properties": {
    "id": { "type": "string" },
    "task": { "type": "string" },
    "canonicalFamily": { "type": "string" },
    "relationship": { "type": "string" },
    "specialization": { "type": "array", "items": { "type": "string" } },
    "catalogueStatus": { "type": "string" },
    "reviewed": { "type": "boolean" },
    "evalPending": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Dimensions requiring a real browser-runtime eval (latency/memory/quality) before a score."
    },
    "dimensions": {
      "type": "object",
      "description": "Each dimension: a score (0-3 or null), a label, a confidence, and evidence[].",
      "required": [
        "capabilityUniqueness",
        "developerValue",
        "browserFeasibility",
        "licenseDeployability",
        "modelCardQuality",
        "maintenanceProvenance",
        "safetyLimitations",
        "overlapWithStronger",
        "showcaseInterest"
      ],
      "properties": {
        "capabilityUniqueness": { "$ref": "#/$defs/dim" },
        "developerValue": { "$ref": "#/$defs/dim" },
        "browserFeasibility": { "$ref": "#/$defs/dim" },
        "licenseDeployability": { "$ref": "#/$defs/dim" },
        "modelCardQuality": { "$ref": "#/$defs/dim" },
        "maintenanceProvenance": { "type": "object" },
        "safetyLimitations": { "type": "object" },
        "overlapWithStronger": { "type": "object" },
        "showcaseInterest": { "$ref": "#/$defs/dim" }
      }
    },
    "overallConfidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "sourceRepo": { "type": ["string", "null"] }
  },
  "$defs": {
    "dim": {
      "type": "object",
      "description": "A scored dimension. score null => not scorable from available evidence.",
      "properties": {
        "score": { "type": ["number", "null"], "minimum": 0, "maximum": 3 },
        "label": { "type": "string" },
        "confidence": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
