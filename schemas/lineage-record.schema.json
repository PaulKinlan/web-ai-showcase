{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lineage record (inventory/lineage/records.ndjson, one JSON object per line)",
  "description": "Provenance/lineage classification of one eligible representative. Separates PROVEN identity (API-confirmed) from INFERRED lineage (name/tag heuristics). NOT a claim of completeness.",
  "type": "object",
  "required": [
    "id",
    "task",
    "runtime",
    "relationship",
    "canonicalFamily",
    "specialization",
    "reviewed",
    "evidence",
    "confidence"
  ],
  "properties": {
    "id": { "type": "string", "description": "Hugging Face model id (owner/name)." },
    "task": { "type": "string" },
    "modality": { "type": "string" },
    "runtime": { "type": "string" },
    "license": { "type": ["string", "null"] },
    "downloads": { "type": "number" },
    "likes": { "type": "number" },
    "gated": { "type": "boolean" },
    "reviewed": {
      "type": "boolean",
      "description": "true = real HF metadata fetched (proven evidence); false = heuristic only."
    },
    "canonicalFamily": {
      "type": "string",
      "description": "Reviewed config.model_type/architecture (proven) else familyKey."
    },
    "base_model": { "type": ["string", "null"] },
    "baseRoot": { "type": ["string", "null"] },
    "relationship": {
      "type": "string",
      "enum": [
        "canonical",
        "exact-dup",
        "format-port",
        "quant-variant",
        "checkpoint",
        "fine-tune",
        "distillation",
        "fork-no-change",
        "specialization-distinct",
        "uncertain"
      ]
    },
    "specialization": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Domain/language/task specialization signals; non-empty => materially-distinct, must NOT be collapsed."
    },
    "catalogueStatus": { "type": "string" },
    "revision": { "type": ["string", "null"] },
    "sourceRepo": { "type": ["string", "null"] },
    "evidence": {
      "type": "object",
      "required": ["proven", "inferred"],
      "properties": {
        "proven": {
          "type": "array",
          "items": { "type": "string" },
          "description": "API-confirmed identity: cardData.base_model, config.architectures, siblings, sha."
        },
        "inferred": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Heuristic lineage from name/tags/familyKey."
        }
      }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
  }
}
