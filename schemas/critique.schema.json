{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paulkinlan.github.io/web-ai-showcase/schemas/critique.schema.json",
  "title": "web-ai-showcase per-demo critique (_questions.json)",
  "description": "One per built model at models/<slug>/_questions.json. Versioned + mutable — it evolves as the demo is reviewed. Rubric evidence must be REAL and retained. A frontend critique with an empty guidanceConsulted is INCOMPLETE (modern-web-guidance mandate).",
  "type": "object",
  "required": ["schemaVersion", "id", "revision", "rubric", "guidanceConsulted", "followUpGoals"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "description": "Stable demo id (the model slug)." },
    "revision": { "type": "integer", "minimum": 1, "description": "Bumped on each critique pass." },
    "reviewedAt": { "type": "string" },
    "reviewer": { "type": "string" },
    "frontend": {
      "type": "boolean",
      "description": "Whether this critique covers frontend (HTML/CSS/JS) work. Defaults true; only false exempts empty guidanceConsulted."
    },
    "rubric": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dimension", "score", "severity", "evidence"],
        "additionalProperties": true,
        "properties": {
          "dimension": {
            "enum": [
              "real-inference",
              "io-shape",
              "runtime-config",
              "cache-init",
              "states",
              "controls",
              "no-fake-output",
              "accessibility",
              "responsive",
              "performance"
            ]
          },
          "score": { "type": "number", "minimum": 0, "maximum": 5 },
          "severity": { "enum": ["info", "minor", "major", "critical"] },
          "evidence": {
            "type": "string",
            "description": "Concrete retained browser/runtime evidence: screenshot path, console excerpt, latency, output sample."
          },
          "notes": { "type": "string" }
        }
      }
    },
    "guidanceConsulted": {
      "type": "array",
      "description": "modern-web-guidance ids/queries consulted for this frontend work + how applied or excepted. Empty on a frontend critique = INCOMPLETE.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "query": { "type": "string" },
          "recommendation": { "type": "string" },
          "appliedOrException": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    },
    "openQuestions": { "type": "array", "items": { "type": "string" } },
    "followUpGoals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["goal", "kind"],
        "properties": {
          "goal": { "type": "string" },
          "kind": { "enum": ["additive-demo", "targeted-fix"] },
          "priority": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "summary": { "type": "string" }
  }
}
