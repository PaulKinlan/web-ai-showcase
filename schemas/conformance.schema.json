{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paulkinlan.github.io/web-ai-showcase/schemas/conformance.schema.json",
  "title": "web-ai-showcase immutable conformance suite",
  "description": "One per built model at models/<slug>/conformance.json. Immutable once committed: assertions are never deleted, weakened, or regenerated to go green — you fix the demo instead. scripts/check-conformance.mjs recomputes suiteHash and diffs against origin/main to detect weakening without a migration record.",
  "type": "object",
  "required": ["schemaVersion", "id", "immutable", "suiteHash", "assertions"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": {
      "type": "string",
      "description": "Stable demo id (the model slug); must map to a built models.json entry."
    },
    "immutable": { "const": true },
    "route": { "type": "string" },
    "identity": {
      "type": "object",
      "properties": {
        "hfId": { "type": ["string", "null"] },
        "task": { "type": ["string", "null"] },
        "backend": { "type": ["string", "null"] }
      }
    },
    "generatedAt": { "type": "string" },
    "author": { "type": "string" },
    "suiteHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "sha256 of the normalized assertions array. The gate recomputes it; a mismatch or a changed/removed assertion vs origin/main without a migration record fails."
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "describe", "kind", "deviceClass"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "category": {
            "enum": [
              "real-inference",
              "io-shape",
              "runtime-config",
              "cache-init",
              "states",
              "controls",
              "no-fake-output",
              "accessibility",
              "responsive",
              "performance",
              "build-process"
            ]
          },
          "describe": {
            "type": "string",
            "description": "The contract the assertion enforces (human-readable)."
          },
          "kind": {
            "enum": [
              "console-clean",
              "dom",
              "page-text",
              "script",
              "source",
              "capability",
              "responsive",
              "manual-evidenced"
            ]
          },
          "deviceClass": { "enum": ["both", "desktop", "mobile", "n/a"] },
          "test": {
            "description": "Payload; semantics depend on kind (selector/substring/JS expr/source pattern/capability probe/responsive assert). manual-evidenced has none."
          },
          "expect": {}
        }
      }
    }
  }
}
