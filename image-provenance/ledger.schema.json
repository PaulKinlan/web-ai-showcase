{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/PaulKinlan/web-ai-showcase/image-provenance/ledger.schema.json",
  "title": "web-ai-showcase site-wide image provenance ledger",
  "type": "object",
  "required": ["name", "version", "generated", "policy", "totals", "entries"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "generated": { "type": "string", "format": "date" },
    "policy": { "type": "array", "items": { "type": "string" } },
    "totals": { "type": "object" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "hash",
          "archetype",
          "depictsPeople",
          "depictsIdentifiablePerson",
          "rightsCleared",
          "provenance",
          "evidence",
          "paths"
        ],
        "properties": {
          "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 },
          "fileCount": { "type": "integer", "minimum": 1 },
          "archetype": {
            "enum": [
              "media-library",
              "licensed-derived",
              "media-derived",
              "procedural",
              "qa-screenshot"
            ]
          },
          "depictsPeople": { "type": "boolean" },
          "depictsIdentifiablePerson": { "type": "boolean" },
          "rightsCleared": { "type": "boolean" },
          "provenance": {
            "type": "object",
            "required": ["kind", "license"],
            "properties": {
              "kind": { "enum": ["licensed", "first-party"] },
              "sourceAsset": { "type": "string" },
              "source": { "type": "string" },
              "sourceUrl": { "type": "string" },
              "creator": { "type": "string" },
              "license": { "type": "string" },
              "licenseName": { "type": "string" },
              "attribution": { "type": "string" }
            }
          },
          "evidence": { "type": "string" },
          "paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    }
  }
}
