{
  "license": "Apache-2.0",
  "tasks": {
    "serve": "deno run --allow-net --allow-read jsr:@std/http/file-server",
    "discover": "node scripts/discover-models.mjs",
    "fmt": "deno fmt",
    "check": "deno check lib/*.js scripts/*.mjs",
    "gate": "node scripts/check-routes.mjs && node scripts/check-conformance.mjs",
    "conformance": "node scripts/conformance.mjs --all",
    "responsive": "node scripts/responsive-check.mjs",
    "goals": "node scripts/goals.mjs"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "exclude": [
      "**/*.html",
      "**/*.css",
      "models.json",
      "reports/",
      "goals.json",
      "**/conformance.json",
      "**/_questions.json",
      "migrations.json",
      "conformance-migrations.json"
    ]
  }
}
